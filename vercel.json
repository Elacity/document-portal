{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/terms-of-service",
      "destination": "/legal/terms-of-service",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/legal/privacy-policy",
      "permanent": true
    },
    {
      "source": "/terms",
      "destination": "/legal/terms-of-service",
      "permanent": true
    },
    {
      "source": "/privacy",
      "destination": "/legal/privacy-policy",
      "permanent": true
    }
  ]
}
